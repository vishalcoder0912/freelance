generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  MENTOR
  RECRUITER
  ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  PENDING
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum NotificationType {
  ASSIGNMENT
  SESSION
  PLACEMENT
  MENTORSHIP
  PAYMENT
  GENERAL
}

enum ContentType {
  LESSON
  ASSIGNMENT
  PROJECT
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?
  name          String
  phone         String?
  avatar        String?
  role          Role      @default(STUDENT)
  firebaseUid   String?   @unique
  isEmailVerified Boolean @default(false)
  isActive      Boolean   @default(true)
  isLocked      Boolean   @default(false)
  lockedAt      DateTime?
  lockedReason  String?
  lastLoginAt   DateTime?
  loginAttempts Int       @default(0)
  resetToken    String?
  resetTokenExpiry DateTime?
  otp           String?
  otpExpiry     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments        Enrollment[]
  assignments        Assignment[]
  submissions        Submission[]
  certificates       Certificate[]
  mentorSessions     MentorSession[]   @relation("Mentor")
  studentSessions    MentorSession[]   @relation("Student")
  jobs               Job[]             @relation("Recruiter")
  applications       Application[]
  placements         Placement[]
  payments           Payment[]
  notifications      Notification[]
  mentorProfile      MentorProfile?
  resumeAnalyses     ResumeAnalysis[]
  careerAnalyses     CareerAnalysis[]
  interviewSessions  InterviewSession[]
  auditLogs          AuditLog[]

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model MentorProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  bio         String?
  expertise   String[]
  experience  Int?
  linkedin    String?
  rating      Float    @default(0)
  totalSessions Int    @default(0)
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Program {
  id            String   @id @default(uuid())
  title         String
  slug          String   @unique
  description   String
  shortDescription String?
  category      String
  duration      Int
  durationUnit  String   @default("weeks")
  level         DifficultyLevel @default(BEGINNER)
  price         Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @db.Decimal(10, 2)
  thumbnail     String?
  banner        String?
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  maxStudents   Int?
  currentStudents Int    @default(0)
  rating        Float    @default(0)
  totalReviews  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  modules       Module[]
  enrollments   Enrollment[]
  certificates  Certificate[]

  @@index([slug])
  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
}

model Module {
  id          String   @id @default(uuid())
  programId   String
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program  Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@index([programId])
  @@index([order])
}

model Lesson {
  id          String   @id @default(uuid())
  moduleId    String
  title       String
  description String?
  content     String?
  videoUrl    String?
  duration    Int?
  order       Int
  isPreview   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module     Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  contents   Content[]

  @@index([moduleId])
  @@index([order])
}

model Content {
  id          String      @id @default(uuid())
  lessonId    String
  type        ContentType
  title       String
  body        String?
  fileUrl     String?
  order       Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Enrollment {
  id          String           @id @default(uuid())
  userId      String
  programId   String
  status      EnrollmentStatus @default(PENDING)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  progress    Float            @default(0)
  certificateId String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([userId])
  @@index([programId])
  @@index([status])
}

model Assignment {
  id          String   @id @default(uuid())
  programId   String
  title       String
  description String?
  dueDate     DateTime?
  maxScore    Int      @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Submission[]

  @@index([programId])
  @@index([isActive])
}

model Submission {
  id           String   @id @default(uuid())
  assignmentId String
  userId       String
  content      String?
  fileUrl      String?
  score        Int?
  feedback     String?
  reviewedBy   String?
  reviewedAt   DateTime?
  submittedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@index([assignmentId])
  @@index([userId])
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  githubUrl   String?
  liveUrl     String?
  technologies String[]
  score       Int?
  feedback    String?
  reviewedBy  String?
  reviewedAt  DateTime?
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Certificate {
  id            String   @id @default(uuid())
  certificateId String   @unique
  userId        String
  programId     String
  issuedAt      DateTime @default(now())
  expiresAt     DateTime?
  pdfUrl        String?
  isRevoked     Boolean  @default(false)
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([certificateId])
  @@index([userId])
  @@index([programId])
}

model Employer {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  logo        String?
  website     String?
  industry    String?
  size        String?
  location    String?
  description String?
  isVerified  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs Job[]

  @@index([email])
  @@index([isActive])
}

model Job {
  id            String      @id @default(uuid())
  employerId    String
  recruiterId   String
  title         String
  description   String?
  requirements  String[]
  responsibilities String[]
  location      String?
  isRemote      Boolean     @default(false)
  jobType       JobType     @default(FULL_TIME)
  salaryMin     Decimal?    @db.Decimal(10, 2)
  salaryMax     Decimal?    @db.Decimal(10, 2)
  salaryCurrency String    @default("INR")
  experienceMin Int?
  experienceMax Int?
  isActive      Boolean     @default(true)
  deadline      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  employer     Employer      @relation(fields: [employerId], references: [id], onDelete: Cascade)
  recruiter    User          @relation("Recruiter", fields: [recruiterId], references: [id], onDelete: Cascade)
  applications Application[]
  placements   Placement[]

  @@index([employerId])
  @@index([recruiterId])
  @@index([isActive])
  @@index([jobType])
}

model Application {
  id          String          @id @default(uuid())
  jobId       String
  userId      String
  status      ApplicationStatus @default(PENDING)
  resumeUrl   String?
  coverLetter String?
  notes       String?
  appliedAt   DateTime        @default(now())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@index([status])
}

model Placement {
  id            String          @id @default(uuid())
  applicationId String          @unique
  jobId         String
  userId        String
  status        String          @default("PENDING")
  offeredAt     DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  joiningDate   DateTime?
  ctc           Decimal?        @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  job         Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
  @@index([status])
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  razorpayOrderId String?
  razorpayPaymentId String?
  razorpaySignature String?
  refundId        String?
  refundAmount    Decimal?      @db.Decimal(10, 2)
  refundReason    String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([razorpayPaymentId])
}

model Notification {
  id        String         @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean        @default(false)
  metadata  Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
}

model MentorSession {
  id          String    @id @default(uuid())
  mentorId    String
  studentId   String
  scheduledAt DateTime
  duration    Int       @default(60)
  topic       String?
  notes       String?
  rating      Int?
  status      String    @default("SCHEDULED")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  mentor  User @relation("Mentor", fields: [mentorId], references: [id], onDelete: Cascade)
  student User @relation("Student", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([studentId])
  @@index([scheduledAt])
}

model ResumeAnalysis {
  id          String   @id @default(uuid())
  userId      String
  fileName    String
  fileUrl     String?
  atsScore    Float?
  keywords    String[]
  suggestions String[]
  rawText     String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CareerAnalysis {
  id          String   @id @default(uuid())
  userId      String
  resumeText  String?
  careerScore Float?
  skillGaps   String[]
  recommendations String[]
  salaryPrediction Json?
  roadmap     Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model InterviewSession {
  id          String   @id @default(uuid())
  userId      String
  type        String
  questions   Json[]
  answers     Json[]
  score       Float?
  feedback    String?
  duration    Int?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  thumbnail   String?
  authorId    String?
  tags        String[]
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@index([authorId])
}

model Faculty {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  designation String?
  bio         String?
  avatar      String?
  linkedin    String?
  expertise   String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([isActive])
}

model Achiever {
  id          String   @id @default(uuid())
  name        String
  email       String?
  program     String
  company     String?
  designation String?
  image       String?
  testimonial String?
  rating      Int?
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isFeatured])
}

model CareerPath {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String?
  skills      String[]
  avgSalary   Decimal? @db.Decimal(10, 2)
  growthRate  Float?
  demand      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}
